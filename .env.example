# Copy to `.env` (gitignored — never commit it). Loaded by `langgraph dev`
# (via langgraph.json "env": ".env") and by app.py (via load_dotenv()).

# Required: OpenAI-compatible API key for the agent's model.
OPENAI_API_KEY=

# Optional: route OpenAI calls through a gateway / custom OpenAI-compatible
# endpoint. Read only here (deploy config), never from chat input.
# OPENAI_BASE_URL=https://your-gateway.example.com/v1

# Optional: model id as provider:model. Defaults to openai:gpt-5-mini.
# MODEL=openai:gpt-5-mini

# Where the Gradio app (app.py) reaches the Agent Server.
# Default = the local `langgraph dev` server.
# LANGGRAPH_URL=http://127.0.0.1:2024

# --- LangSmith tracing (enabled) -------------------------------------------
# Agent runs are traced to LangSmith. These are read by `langgraph dev` (the
# server that runs the graph) and by app.py. Put your real key in .env only —
# never commit it. `langgraph dev` traces fine with any valid key (no LangGraph
# Platform entitlement needed).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
# Optional: only for a non-default / regional LangSmith host (e.g. EU).
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
